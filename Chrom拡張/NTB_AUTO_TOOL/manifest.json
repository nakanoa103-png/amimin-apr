{
  "manifest_version": 3,
  "name": "MAPS X 自動出力ロボ",
  "version": "1.0.0",
  "description": "拠点コードを切り替えて帳票を連続出力します",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}